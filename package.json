{
  "name": "running-ai-assistant",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "build": "npm run build --workspace @running-ai/api",
    "build:web": "npm run build --workspace @running-ai/web",
    "build:all": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace @running-ai/api",
    "dev:web": "npm run dev --workspace @running-ai/web",
    "test": "npm run test --workspace @running-ai/api",
    "prisma:generate": "npm run prisma:generate --workspace @running-ai/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @running-ai/api"
  }
}
